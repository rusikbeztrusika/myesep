function createDefaultSubscription() {
  return {
    plan: "free",
    status: "free",
    trialStartedAt: "",
    trialEndsAt: "",
    proStartedAt: ""
  };
}

function normalizeSubscription(raw) {
  const base = createDefaultSubscription();
  const next = raw && typeof raw === "object" ? { ...base, ...raw } : base;

  const allowedPlans = ["free", "pro"];
  const allowedStatuses = ["free", "trialing", "active", "expired"];

  next.plan = allowedPlans.includes(next.plan) ? next.plan : "free";
  next.status = allowedStatuses.includes(next.status) ? next.status : next.plan === "pro" ? "active" : "free";
  next.trialStartedAt = String(next.trialStartedAt || "");
  next.trialEndsAt = String(next.trialEndsAt || "");
  next.proStartedAt = String(next.proStartedAt || "");

  return next;
}

