  const hasAdvancedAnalytics = canUseFeature("advanced_analytics");
  const taxLoadPayNow = Math.max(0, Math.round(Number(currentTax.opv || 0) + Number(currentTax.so || 0) + Number(currentTax.opvr || 0) + Number(currentTax.vosms || 0)));
