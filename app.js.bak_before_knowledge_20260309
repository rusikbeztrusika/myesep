function ensureTrialIfNeeded() {
  refreshSubscriptionState();

  if (state.subscription.plan === "pro") {
    return;
  }

  if (!state.subscription.trialStartedAt) {
    const start = new Date();
    const end = new Date(start);
    end.setDate(end.getDate() + TRIAL_DAYS);

    state.subscription.status = "trialing";
    state.subscription.trialStartedAt = start.toISOString();
    state.subscription.trialEndsAt = end.toISOString();
    state.paywallFeature = "";
    refreshSubscriptionState();
    saveState();
    trackEvent("trial_started", { days: TRIAL_DAYS });
    return;
  }

  refreshSubscriptionState();
  saveState();
}

