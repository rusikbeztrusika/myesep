  }
  updateAuthUi();

  if (supabaseClient) {
    const { data } = await supabaseClient.auth.getSession();
    if (data.session && data.session.user) {
      state.isLoggedIn = true;
      state.userEmail = data.session.user.email || state.userEmail;
