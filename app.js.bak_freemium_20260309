function getLandingDayWord(days) {
  const mod10 = days % 10;
  const mod100 = days % 100;
  if (mod10 === 1 && mod100 !== 11) return "день";
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 10 || mod100 >= 20)) return "дня";
  return "дней";
}

function getLandingDeadlineDueInfo(dateString) {
  const now = new Date();
  const dayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const target = new Date(dateString);
  const targetStart = new Date(target.getFullYear(), target.getMonth(), target.getDate());
  const days = Math.max(0, Math.ceil((targetStart - dayStart) / 86400000));

  if (days === 0) return { text: "Сегодня", tone: "urgent" };
  if (days === 1) return { text: "Завтра", tone: "urgent" };
  if (days <= 7) return { text: `Через ${days} ${getLandingDayWord(days)}`, tone: "urgent" };
  if (days <= 14) return { text: `Через ${days} ${getLandingDayWord(days)}`, tone: "soon" };

  return { text: `Через ${days} ${getLandingDayWord(days)}`, tone: "" };
}

