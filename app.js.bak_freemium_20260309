function calcSelfEmployed(income) {
  const esp = RATES.MRP;
  return { esp, opv: 0, so: 0, vosms: 0, ipn: 0, socTax: 0, total: esp, limit: 13760000 };
}

function calcSimplified(income) {
  const opv = Math.min(income * RATES.OPV_RATE, RATES.MAX_OPV_BASE);
  const so = (income - opv) * RATES.SO_RATE;
  const vosms = RATES.VOSMS;
  const ipn = (income * 0.03) / 6;
  const socTax = Math.max(income * 0.03 - so, 0);
  const total = opv + so + vosms + ipn + socTax;
  return { opv, so, vosms, ipn, socTax, total, limit: 94500000 };
}

function calcOUR(income, expenses = 0) {
  const opv = Math.min(income * RATES.OPV_RATE, RATES.MAX_OPV_BASE);
  const so = (income - opv) * RATES.SO_RATE;
  const vosms = RATES.VOSMS;
  const taxBase = Math.max(income - expenses - opv, 0);
  const ipn = (taxBase * 0.1) / 12;
  const total = opv + so + vosms + ipn;
  return { opv, so, vosms, ipn, socTax: 0, total, limit: null };
}

function calcByRegime(regime, income, expenses = 0) {
  if (regime === "self") return calcSelfEmployed(income);
  if (regime === "our") return calcOUR(income, expenses);
  return calcSimplified(income);
}

function fmt(value) {
  return `${new Intl.NumberFormat("ru-KZ").format(Math.round(value || 0))} ₸`;
}

function normalizeIncome(value) {
  return Math.max(0, Math.round(Number(value) || 0));
}

function getLandingPeriodMultiplier() {
  return state.landingPeriod === "year" ? 12 : 1;
}
function annualizeIncome(monthlyIncome) {
  return Math.max(0, Number(monthlyIncome) || 0) * 12;
}

function getRegimeLimit(regime) {
  if (regime === "self") return RATES.MRP * 1175;
  if (regime === "simplified") return 94500000;
  return null;
}

function getRegimeAvailability(regime, monthlyIncome) {
  const limit = getRegimeLimit(regime);
  if (!limit) {
    return { available: true, reason: "" };
  }

  const annualIncome = annualizeIncome(monthlyIncome);
  if (annualIncome <= limit) {
    return { available: true, reason: "" };
  }

  return {
    available: false,
    reason: `Превышен лимит ${fmt(limit)} в год`
  };
}

