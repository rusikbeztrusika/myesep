                  <td><button class="btn btn-ghost" data-toggle-deadline="${row.id}">${done ? "Отменить" : "Отметить"}</button></td>
                </tr>
              `;
            })
            .join("")}
        </tbody>
      </table>
    </article>
  `;
}

function renderCalculatorPage() {
  const rows = [
    { id: "self", label: "Самозанятый", taxData: calcSelfEmployed(state.calcIncome), limitLabel: "13.76 млн ₸/год" },
    { id: "simplified", label: "Упрощенка (910)", taxData: calcSimplified(state.calcIncome), limitLabel: "94.5 млн ₸/год" },
    { id: "our", label: "ОУР", taxData: calcOUR(state.calcIncome, state.calcExpenses), limitLabel: "Без лимита" }
  ].map((row) => ({
    ...row,
    tax: row.taxData.total,
    ...getRegimeAvailability(row.id, state.calcIncome)
  }));

  const availableRows = rows.filter((row) => row.available).sort((a, b) => a.tax - b.tax);
  const fallbackRows = [...rows].sort((a, b) => a.tax - b.tax);
  const bestId = (availableRows[0] || fallbackRows[0]).id;

  els.pageContent.innerHTML = `
    <article class="card">
      <h3>Параметры расчета</h3>
      <div class="grid grid-2">
        <label>Ежемесячный доход (₸)
          <input id="calcIncomeInput" type="number" value="${state.calcIncome}" min="0" step="10000" />
        </label>
        <label>Расходы (₸) - для ОУР
          <input id="calcExpensesInput" type="number" value="${state.calcExpenses}" min="0" step="10000" />
        </label>
      </div>
    </article>

    <div class="grid grid-3 mt-16">
      ${rows.map((row) => renderRegimeResultCard(row, bestId)).join("")}
    </div>
  `;

  const calcIncomeInput = document.getElementById("calcIncomeInput");
  const calcExpensesInput = document.getElementById("calcExpensesInput");

  calcIncomeInput.addEventListener("input", () => {
    state.calcIncome = Number(calcIncomeInput.value || 0);
    saveState();
    renderCalculatorPage();
    trackEvent("calc_change");
  });

  calcExpensesInput.addEventListener("input", () => {
    state.calcExpenses = Number(calcExpensesInput.value || 0);
    saveState();
    renderCalculatorPage();
    trackEvent("calc_change");
  });
}

function renderRegimeResultCard(row, bestId) {
  const isBest = row.id === bestId && state.calcIncome > 0 && row.available;

  return `
    <article class="card regime-result ${isBest ? "best" : ""} ${row.available ? "" : "unavailable"}">
      ${isBest ? '<span class="badge badge-success top-badge">ВЫГОДНЕЕ ✓</span>' : row.available ? "" : '<span class="badge badge-warning top-badge">Недоступно</span>'}
      <h3>${row.label}</h3>
      <div class="stat-value ${isBest ? "" : "stat-danger"} stat-xl">${fmt(row.tax)}</div>
      <p class="text-muted">в месяц · лимит: ${row.limitLabel}</p>
      ${row.available ? renderTaxBreakdown(row.taxData, row.id) : `<p class="text-muted">${row.reason}. Рассмотрите другой режим.</p>`}
    </article>
  `;
}
