function renderTaxesPage() {
  const monthlyData = getMonthlyData();
  const rows = monthlyData.map((row) => {
    const tax = calcByRegime(state.regime, row.income, state.calcExpenses).total;
    return `<tr><td>${row.name}</td><td>${fmt(row.income)}</td><td>${fmt(tax)}</td></tr>`;
  });

  const monthTax = getCurrentTax();
  const avgMonthlyIncome = getTotalIncome() / Math.max(new Date().getMonth() + 1, 1);
  const annualForecast = calcByRegime(state.regime, avgMonthlyIncome, state.calcExpenses).total * 12;

  els.pageContent.innerHTML = `
    <div class="grid grid-2">
      <article class="card">
        <h3>Текущий месяц</h3>
        ${renderTaxBreakdown(monthTax, state.regime)}
      </article>

      <article class="card">
        <h3>Прогноз на 12 месяцев</h3>
        <div class="stat-value stat-danger">${fmt(annualForecast)}</div>
        <p class="text-muted">Оценка по среднему доходу ${fmt(avgMonthlyIncome)} в месяц.</p>
      </article>
    </div>

    <article class="card mt-16">
      <h3>Помесячный прогноз</h3>
      <table class="table">
        <thead><tr><th>Месяц</th><th>Доход</th><th>Налоги</th></tr></thead>
        <tbody>${rows.join("")}</tbody>
      </table>
    </article>
  `;
}

function renderCalendarPage() {
  const rows = DEADLINES_2026
    .filter((d) => d.regime === state.regime || d.regime === "all")
    .sort((a, b) => new Date(a.date) - new Date(b.date));

  els.pageContent.innerHTML = `
    <article class="card">
      <h3>Календарь сроков по режиму: ${regimeLabel(state.regime)}</h3>
      <table class="table">
        <thead><tr><th>Дата</th><th>Событие</th><th>Тип</th><th>Статус</th><th></th></tr></thead>
        <tbody>
          ${rows
            .map((row) => {
              const done = state.doneDeadlines.includes(row.id);
              return `
                <tr>
                  <td>${formatDate(row.date)}</td>
                  <td>${row.title}</td>
                  <td>${row.type === "payment" ? "Платеж" : "Отчет"}</td>
                  <td>${
                    done
                      ? '<span class="badge badge-success">Сделано</span>'
                      : '<span class="badge badge-warning">Ожидает</span>'
